{
  "ConnectionStrings": {
    "DefaultConnection": "__SET_DEFAULT_CONNECTION__"
  },
  "Twilio": {
    "AccountSid": "test_account_sid",
    "AuthToken": "test_auth_token",
    "FromPhoneNumber": "+1234567890"
  },
  "ImageKit": {
    "PublicKey": "__SET_IMAGEKIT_PUBLIC_KEY__",
    "PrivateKey": "__SET_IMAGEKIT_PRIVATE_KEY__",
    "UrlEndpoint": "__SET_IMAGEKIT_URL_ENDPOINT__"
  },
  "JwtSettings": {
    "Secret": "__SET_JWT_SECRET__",
    "Issuer": "ZadanaApi",
    "Audience": "ZadanaClients",
    "ExpiryMinutes": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  }
}
